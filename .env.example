# SentimentFlow — Environment Variables
# Copy to .env and fill in your values before running docker compose up

# ── Model ────────────────────────────────────────────────────────────────────
MODEL_NAME=cardiffnlp/twitter-roberta-base-sentiment-latest
MODEL_CACHE_DIR=./models/cache

# ── API ───────────────────────────────────────────────────────────────────────
API_PORT=8080
API_TITLE=SentimentFlow API
API_VERSION=0.1.0
METRICS_PORT=8000
LOG_LEVEL=INFO
MAX_BATCH_SIZE=32
DEVICE=cpu                          # set to "cuda" if GPU available

# ── MLflow (optional — leave empty to disable experiment tracking) ────────────
MLFLOW_TRACKING_URI=                # e.g. http://localhost:5000 if you run MLflow separately

# ── Grafana ───────────────────────────────────────────────────────────────────
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

# ── RapidAPI / Twitter (optional — only needed for live tweet ingestion) ──────
RAPIDAPI_KEY=your-rapidapi-key-here
TWITTER_API_HOST=twitter154.p.rapidapi.com

# ── Airflow (only needed if running full Airflow stack) ───────────────────────
AIRFLOW__CORE__FERNET_KEY=46BKJoQYlPPOexq0OhDZnIlNepKFf87WFwLbfzqDDho=
AIRFLOW_POSTGRES_USER=airflow
AIRFLOW_POSTGRES_PASSWORD=airflow
AIRFLOW_POSTGRES_DB=airflow

# ── Datasets ──────────────────────────────────────────────────────────────────
PRIMARY_DATASET=tweet_eval
PRIMARY_DATASET_CONFIG=sentiment
SECONDARY_DATASET=mteb/amazon_reviews_multi
SKIP_DATASETS=                      # comma-separated dataset names to skip in evaluation
